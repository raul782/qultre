---
import BaseLayout from '@layouts/BaseLayout.astro';
import HeroScene from '@components/HeroScene';
import ThreeCard from '@components/ThreeCard';
import WaitlistForm from '@components/WaitlistForm';

const lang = "en";
---

<BaseLayout title="Qultre - Beyond Borders" lang={lang} description="Explore native cultures through spatial deck interfaces and atomic, district-level data. Join the waitlist.">
  
  {/* Spatial Background */}
  <HeroScene client:only="react" lang={lang} />

  {/* Scrollable Foreground Container */}
  <div class="relative z-10 w-full min-h-screen pointer-events-none select-none">
    
    {/* Screen 1: Cinematic Spatial Hero */}
    <section class="min-h-screen w-full flex flex-col justify-between items-center p-6 text-center">
      
      {/* Spacer for sticky header padding */}
      <div class="h-20"></div>

      {/* Hero Headings Overlay */}
      <div class="max-w-4xl space-y-6 my-auto px-4 pointer-events-auto select-text">
        <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest bg-primary-500/10 dark:bg-primary-500/20 text-primary-600 dark:text-primary-400 border border-primary-500/20">
          Beyond Borders
        </span>
        <h1 class="text-4xl sm:text-6xl md:text-8xl font-black font-display tracking-tight text-slate-900 dark:text-white uppercase leading-none">
          The World is More Than Headlines.<br />
          <span class="bg-gradient-to-r from-primary-500 via-secondary-500 to-accent-400 bg-clip-text text-transparent">
            Connect Deeper.
          </span>
        </h1>
        <p class="text-base sm:text-lg md:text-xl text-slate-600 dark:text-slate-300 font-medium tracking-wide max-w-xl mx-auto leading-relaxed">
          Select a city from the interactive deck or spin the globe to dive into atomic, district-level realities and native customs.
        </p>
      </div>

      <!-- Scroll indicator -->
      <div class="pb-16 animate-bounce pointer-events-auto">
        <a href="#explorer" class="flex flex-col items-center gap-1 text-[10px] uppercase font-extrabold tracking-widest text-slate-400 hover:text-primary-500 transition-colors">
          <span>Explore Deck</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
        </a>
      </div>
    </section>

    {/* Screen 2: Interactive Explorer (HTML Card display) */}
    <section id="explorer" class="min-h-screen w-full bg-slate-50/70 dark:bg-slate-950/70 backdrop-blur-sm border-t border-slate-200/50 dark:border-slate-800/50 py-24 px-6 flex flex-col justify-center items-center pointer-events-auto select-text">
      <div class="max-w-7xl mx-auto text-center space-y-16 w-full">
        <div class="max-w-2xl mx-auto space-y-4">
          <h2 class="text-3xl md:text-5xl font-black font-display tracking-tight text-slate-900 dark:text-white uppercase">
            Card Deck
          </h2>
          <p class="text-slate-500 dark:text-slate-400 font-light text-sm sm:text-base">
            Explore focused city attributes. Toggle categories to reveal actual data from the Culture Graph on local rates, transit guides, and customs.
          </p>
        </div>
        <ThreeCard client:only="react" lang={lang} />
      </div>
    </section>

    {/* Screen 3: Graph Vision Details */}
    <section class="py-24 bg-slate-100/80 dark:bg-slate-900/60 border-t border-slate-200/50 dark:border-slate-800/50 pointer-events-auto select-text relative">
      <div class="max-w-7xl mx-auto px-6 text-center space-y-16">
        <div class="max-w-2xl mx-auto space-y-4">
          <h2 class="text-3xl md:text-5xl font-black font-display tracking-tight text-slate-900 dark:text-white uppercase">
            Unveiling the Culture Graph
          </h2>
          <p class="text-slate-500 dark:text-slate-400 font-light text-base">
            How Qultre connects local micro-information into a unified network of discovery.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="p-8 glass rounded-3xl border border-slate-200/50 dark:border-slate-800/50 text-left space-y-4 shadow-sm hover:shadow-md transition-shadow">
            <div class="w-12 h-12 bg-primary-500/10 text-primary-600 dark:text-primary-400 rounded-2xl flex items-center justify-center font-bold font-display text-xl">
              1
            </div>
            <h3 class="text-xl font-bold font-display text-slate-900 dark:text-white">Zoom into the Neighborhood</h3>
            <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed font-light">
              Skip the tourist traps. Drop straight into the local rhythm with secrets curated by people who actually live there.
            </p>
          </div>

          <div class="p-8 glass rounded-3xl border border-slate-200/50 dark:border-slate-800/50 text-left space-y-4 shadow-sm hover:shadow-md transition-shadow">
            <div class="w-12 h-12 bg-secondary-500/10 text-secondary-600 dark:text-secondary-400 rounded-2xl flex items-center justify-center font-bold font-display text-xl">
              2
            </div>
            <h3 class="text-xl font-bold font-display text-slate-900 dark:text-white">Pocket-Sized City Guides</h3>
            <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed font-light">
              Tap a card to unlock instant, offline-ready street smarts—from buying a train ticket without looking lost to ordering coffee like a native.
            </p>
          </div>

          <div class="p-8 glass rounded-3xl border border-slate-200/50 dark:border-slate-800/50 text-left space-y-4 shadow-sm hover:shadow-md transition-shadow">
            <div class="w-12 h-12 bg-accent-500/10 text-accent-600 dark:text-accent-400 rounded-2xl flex items-center justify-center font-bold font-display text-xl">
              3
            </div>
            <h3 class="text-xl font-bold font-display text-slate-900 dark:text-white">Discover Invisible Threads</h3>
            <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed font-light">
              See how the world connects. Fall in love with a hidden jazz alley in Madrid, and let Qultre reveal its sister district waiting for you in Lisbon.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* Screen 4: waitlist form Zone */}
    <section id="waitlist" class="min-h-screen w-full bg-gradient-to-t from-slate-100 via-slate-50/90 to-transparent dark:from-slate-950 dark:via-slate-950/90 dark:to-transparent border-t border-slate-200/50 dark:border-slate-800/50 flex flex-col justify-center items-center py-24 px-6 pointer-events-auto select-text">
      <WaitlistForm client:load lang={lang} />
    </section>

    {/* Screen 5: FAQs Panel */}
    <section id="faq" class="py-24 bg-white/70 dark:bg-slate-950/70 backdrop-blur-md border-t border-slate-200/50 dark:border-slate-800/50 pointer-events-auto select-text">
      <div class="max-w-4xl mx-auto px-6 space-y-12">
        <div class="text-center space-y-4">
          <h2 class="text-3xl md:text-5xl font-black font-display tracking-tight text-slate-900 dark:text-white uppercase">
            Frequently Asked Questions
          </h2>
          <p class="text-slate-500 dark:text-slate-400 font-light text-base">
            Everything you need to know about the Qultre project.
          </p>
        </div>

        <div class="space-y-6">
          <div class="p-6 glass rounded-2xl border border-slate-200/50 dark:border-slate-800/50 space-y-2">
            <h3 class="text-lg font-bold font-display text-slate-900 dark:text-white">
              What exactly is Qultre?
            </h3>
            <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed font-light">
              Think of it as a living map that connects countries, cities, and neighborhoods together. Instead of jumping between ten different blogs, translation apps, and transit guides, Qultre weaves everything into a single visual story so you can step off the plane feeling like a local.
            </p>
          </div>

          <div class="p-6 glass rounded-2xl border border-slate-200/50 dark:border-slate-800/50 space-y-2">
            <h3 class="text-lg font-bold font-display text-slate-900 dark:text-white">
              How do I use the City Cards?
            </h3>
            <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed font-light">
              They are bite-sized, interactive cheat-sheets for your phone! Tap a city card to get instant, clear answers to on-the-ground questions—like how to buy a metro pass, local tipping rules, or the best neighborhoods to explore without the crowds.
            </p>
          </div>

          <div class="p-6 glass rounded-2xl border border-slate-200/50 dark:border-slate-800/50 space-y-2">
            <h3 class="text-lg font-bold font-display text-slate-900 dark:text-white">
              Is it free to join the waitlist?
            </h3>
            <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed font-light">
              100% free. By dropping your email today, you lock in early "first-wave" access to our pilot city decks before anyone else, helping us shape the ultimate way to see the world.
            </p>
          </div>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>
